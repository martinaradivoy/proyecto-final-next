generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model ContactMessage {
  id        String   @id @default(cuid())
  nombre    String
  email     String
  telefono  String
  mensaje   String
  tipo      String?
  createdAt DateTime @default(now())
}
